{
  "name": "ledger",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Ledger — Household Budget Portal (full-stack)",
  "scripts": {
    "dev": "concurrently -n api,web -c green,blue \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch --env-file=.env server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "vite": "^5.4.0"
  }
}
